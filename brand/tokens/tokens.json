{
  "$schema": "https://design-tokens.org/schema.json",
  "brand": {
    "name": "zkCoins",
    "tagline": "Private Bitcoin transactions via Shielded CSV.",
    "theme": "dark-committed"
  },
  "color": {
    "orange": {
      "50":  { "value": "#fff4e6" },
      "100": { "value": "#ffe4bf" },
      "200": { "value": "#ffce8a" },
      "300": { "value": "#ffb85c" },
      "400": { "value": "#ffa333" },
      "500": { "value": "#f7931a", "comment": "primary accent" },
      "600": { "value": "#e07d0a" },
      "700": { "value": "#b56207" },
      "800": { "value": "#8a4a08" },
      "900": { "value": "#5c320a" }
    },
    "ink": {
      "0": { "value": "#0a0a0a", "comment": "ground" },
      "1": { "value": "#141312" },
      "2": { "value": "#1c1a18" },
      "3": { "value": "#26231f" }
    },
    "border":       { "value": "#2e2a26" },
    "borderStrong": { "value": "#3a352f" },
    "text": {
      "subtle": { "value": "#78726a" },
      "muted":  { "value": "#a8a29a" },
      "body":   { "value": "#ece9e4" },
      "strong": { "value": "#ffffff" }
    },
    "semantic": {
      "success": { "value": "#3fb950" },
      "warning": { "value": "#e3b341" },
      "danger":  { "value": "#f85149" },
      "info":    { "value": "#58a6ff" }
    },
    "espresso": { "value": "radial-gradient(120% 120% at 50% 26%, #a86a1f, #1a1005 82%)", "comment": "signature surface behind the mark" },
    "role": {
      "bg":       { "value": "{color.ink.0}" },
      "surface":  { "value": "{color.ink.2}" },
      "accent":   { "value": "{color.orange.500}" },
      "accentFg": { "value": "#000000", "comment": "default on-accent ink (max contrast); white is also fine for the mark/large display" },
      "link":     { "value": "{color.orange.400}" },
      "focus":    { "value": "{color.orange.300}" }
    }
  },
  "contrast": {
    "note": "Ratios computed against ground #0a0a0a (WCAG 2.1).",
    "accentOnGround": { "ratio": 8.6, "passes": ["AA-normal", "AAA-large"] },
    "strongOnGround": { "ratio": 19.8, "passes": ["AAA-normal"] },
    "mutedOnGround":  { "ratio": 7.8, "passes": ["AAA-normal"] },
    "whiteOnAccent":  { "ratio": 2.3, "passes": [], "comment": "low ratio — fine for the mark/large display, avoid for small body text" },
    "groundOnAccent": { "ratio": 8.6, "passes": ["AA-normal", "AAA-large"], "comment": "use dark text on orange" }
  },
  "font": {
    "mono": { "value": "IBM Plex Mono", "fallback": "SF Mono, ui-monospace, Menlo, monospace", "license": "SIL OFL 1.1" },
    "sans": { "value": "IBM Plex Sans", "fallback": "system-ui, -apple-system, Segoe UI, sans-serif", "license": "SIL OFL 1.1" }
  },
  "scale": {
    "type": { "xs": "12px", "sm": "14px", "base": "16px", "lg": "18px", "xl": "22px", "2xl": "28px", "3xl": "36px", "4xl": "48px", "5xl": "64px" },
    "radius": { "sm": "6px", "md": "10px", "lg": "16px", "pill": "999px" },
    "space": { "1": "4px", "2": "8px", "3": "12px", "4": "16px", "6": "24px", "8": "32px", "12": "48px", "16": "64px", "24": "96px" }
  }
}
